{
  "name": "@chatapp/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node dist/server.js",
    "build": "npm run lint && npm run test && npm run bundle",
    "bundle": "esbuild src/server.js --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external && node scripts/copy-templates.mjs",
    "lint": "eslint .",
    "generate-vapid-keys": "npm exec --workspace server -- web-push generate-vapid-keys",
    "test": "vitest run"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.4",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.2",
    "sanitize-html": "^2.13.1",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.2",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "vitest": "^4.1.2"
  }
}