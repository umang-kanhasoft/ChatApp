# App
NODE_ENV=development
PORT=5000
CLIENT_URL=CLIENT_URL
CLIENT_URLS=

# Database
MONGODB_URI=MONGODB_URI
MONGODB_FALLBACK_TO_MEMORY=true
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGODB_SOCKET_TIMEOUT_MS=10000

# Redis
REDIS_URL=REDIS_URL
REDIS_REQUIRED=true

# Realtime and cache tuning
PRESENCE_ROOM_CACHE_TTL_SECONDS=300

# Auth and sessions
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-at-least-32-chars

# Push notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Email delivery (use either SMTP_* or NODEMAILER_GMAIL_*)
NODEMAILER_GMAIL_ID=
NODEMAILER_GMAIL_PASSWORD=

# Media storage (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
