<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Your ChatApp OTP</title>
    <style>
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background-color: #f8fafc;
        margin: 0;
        padding: 0;
        color: #1e293b;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }
      .header {
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        padding: 32px;
        text-align: center;
        color: #ffffff;
      }
      .header h1 {
        margin: 0;
        font-size: 24px;
        font-weight: 800;
        letter-spacing: -0.025em;
      }
      .content {
        padding: 48px 32px;
        text-align: center;
      }
      .otp-label {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .otp-code {
        font-size: 48px;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: 0.2em;
        background: #f1f5f9;
        padding: 24px 32px;
        border-radius: 12px;
        display: inline-block;
        margin-bottom: 32px;
        border: 2px solid #e2e8f0;
        line-height: 1;
      }
      .expiry-text {
        font-size: 14px;
        color: #64748b;
        line-height: 1.5;
        margin: 8px 0;
      }
      .footer {
        padding: 32px;
        background: #f1f5f9;
        text-align: center;
        font-size: 14px;
        color: #64748b;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>ChatApp</h1>
      </div>
      <div class="content" style="text-align: center;">
        <p class="otp-label">Your Verification Code</p>
        <div class="otp-code">{{code}}</div>
        <p class="expiry-text">This code will expire in 10 minutes.</p>
        <p class="expiry-text">If you didn't request this code, you can safely ignore this email.</p>
      </div>
      <div class="footer">
        <p>&copy; {{year}} ChatApp. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
